// Initialize starting values for the Fibonacci sequence
let x = 0;
let y = 1;
let i = 0; // Loop counter

while (i < 10) {
    print x; // Output the current number
    
    let temp = x + y; // Temporarily store the sum of the last two numbers
    x = y;            // Move 'x' forward to the next number
    y = temp;         // Move 'y' forward to the new sum
    
    i = i + 1;        // Increment counter
}
